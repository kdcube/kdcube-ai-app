DEFAULT_PROJECT_NAME=demo
DEFAULT_TENANT=home
TENANT_ID=home

# If use s3, configure s3://bucket/path
KDCUBE_STORAGE_PATH=file:///Users/<user>/data/kdcube

OPENAI_API_KEY=sk-proj...
HUGGING_FACE_API_TOKEN=hf_...
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_CODE_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-...

# If use s3, provide profile name with list/read/write policies on the bucket
AWS_PROFILE=nestlogic-dev
AWS_REGION=eu-west-1
AWS_DEFAULT_REGION=eu-west-1
AWS_SDK_LOAD_CONFIG=1

# Locally served models (custom provider -> models gateway -> Ollama)
# Outside docker the gateway is on localhost; inside chat-proc it is host.docker.internal.
CUSTOM_MODEL_ENDPOINT=http://localhost:11500/generate
CUSTOM_MODEL_NAME=qwen3.6:35b
# CUSTOM_MODEL_API_KEY=            # only when the gateway sets GATEWAY_API_KEY
