{
  "name": "@kdcube/components-core",
  "version": "0.1.0",
  "description": "Framework-agnostic headless engines for KDCube client components (chat, canvas, …). No React, no iframe assumptions — a vanilla controller per component plus a host event bus.",
  "license": "UNLICENSED",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./chat": {
      "types": "./dist/chat/index.d.ts",
      "import": "./dist/chat/index.js"
    },
    "./events": {
      "types": "./dist/events/index.d.ts",
      "import": "./dist/events/index.js"
    },
    "./scene": {
      "types": "./dist/scene/index.d.ts",
      "import": "./dist/scene/index.js"
    },
    "./canvas": {
      "types": "./dist/canvas/index.d.ts",
      "import": "./dist/canvas/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "npm run build && node --test tests/*.test.mjs",
    "test:chat": "npm run build && node --test tests/chat-accounting-scope.test.mjs",
    "test:events": "npm run build && node --test tests/events-client.test.mjs",
    "test:scene": "npm run build && node --test tests/scene-runtime.test.mjs tests/scene-subscriptions.test.mjs tests/scene-event-bus.test.mjs tests/scene-host-drag.test.mjs tests/scene-drop-targets.test.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.2.0",
    "socket.io-client": "^4.7.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
