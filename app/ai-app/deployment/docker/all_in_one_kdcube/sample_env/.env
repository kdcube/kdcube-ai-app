# =============================================================================
# KDCube AI Platform - Docker Compose Configuration
# =============================================================================
# This file contains build contexts, paths, and docker-compose variables.
# Copy this file and adjust paths for your environment.
#
# For runtime configuration (DB passwords, API keys), see:
#   .env.ingress / .env.proc / .env.metrics / .env.postgres.setup
# This stack runs local Postgres + Redis containers.
# =============================================================================

# -----------------------------------------------------------------------------
# DOCKER-IN-DOCKER PATH MAPPINGS
# -----------------------------------------------------------------------------
# Absolute paths on the host machine for volume mounts

# Workdir layout (config + data + logs)
# If you keep configs in a separate workdir, point these to that root.
KDCUBE_CONFIG_DIR=/absolute/path/to/workdir/config
KDCUBE_DATA_DIR=/absolute/path/to/workdir/data
KDCUBE_LOGS_DIR=/absolute/path/to/workdir/logs

# Path on host to mount as a KDCUBE STORAGE (local filesystem or S3).
# If using S3 in KDCUBE_STORAGE_PATH, not needed
HOST_KDCUBE_STORAGE_PATH=/absolute/path/to/deployment/docker/all_in_one_kdcube/data/kdcube-storage

# Host directory containing ALL custom agentic bundles (subfolders, wheels, zips)
# These extend the chat service with custom Python applications
HOST_BUNDLES_PATH=/absolute/path/to/bundles

# Host directory for git-resolved bundle clones/cache.
# Keep this separate from HOST_BUNDLES_PATH if you want local path bundles and git bundles
# to live in different host folders.
HOST_GIT_BUNDLES_PATH=/absolute/path/to/git-bundles

# Host directory for shared bundle local storage (bundle data; used by ks: resolvers).
# This is mounted into chat-proc at BUNDLE_STORAGE_ROOT.
HOST_BUNDLE_STORAGE_PATH=/absolute/path/to/bundle-storage

# Assembly descriptor (optional; mounted as /config/assembly.yaml)
# If unset, /dev/null is mounted and AGENTIC_BUNDLES_JSON should be inline or empty.
HOST_ASSEMBLY_YAML_DESCRIPTOR_PATH=/absolute/path/to/assembly.yaml

# Bundles descriptor (optional; mounted into chat-proc as /config/bundles.yaml)
# When set, AGENTIC_BUNDLES_JSON should point to /config/bundles.yaml.
HOST_BUNDLES_DESCRIPTOR_PATH=/absolute/path/to/bundles.yaml

# Optional SSH key + known_hosts for git bundle pulls (private repos)
# These files are mounted into the chat-proc container at:
#   /run/secrets/git_ssh_key
#   /run/secrets/git_known_hosts
HOST_GIT_SSH_KEY_PATH=/absolute/path/to/.ssh/id_ed25519
HOST_GIT_KNOWN_HOSTS_PATH=/absolute/path/to/.ssh/known_hosts

# Temporary workspace for code execution (Docker-in-Docker)
HOST_EXEC_WORKSPACE_PATH=/absolute/path/to/deployment/docker/all_in_one_kdcube/data/exec-workspace

# Mount path for bundles inside the container
# DO NOT CHANGE unless you modify AGENTIC_BUNDLES_JSON references
AGENTIC_BUNDLES_ROOT=/bundles

# Mount path for git-resolved bundles inside the container
AGENTIC_GIT_BUNDLES_ROOT=/git-bundles

# Shared bundle storage root inside the container (knowledge space root)
BUNDLE_STORAGE_ROOT=/bundle-storage

# -----------------------------------------------------------------------------
# WEB UI BUILD CONFIGURATION
# -----------------------------------------------------------------------------
# Configuration for building the custom frontend application

# Optional: use a prebuilt UI image instead of building locally.
# When set, docker compose will use this image and the CLI will skip building web-ui.
KDCUBE_UI_IMAGE=

# Root of the KDCube ai-app directory (contains deployment/, ui/, services/)
# This works on Linux/Mac. For Windows, use a Windows-safe path (e.g., D:/path/to/kdcube-ai-app/app/ai-app)
UI_BUILD_CONTEXT=/absolute/path/to/kdcube-ai-app/app/ai-app

# Path to Dockerfile_UI (relative to UI_BUILD_CONTEXT)
UI_DOCKERFILE_PATH=deployment/docker/all_in_one_kdcube/Dockerfile_UI

# Path to UI source code (relative to UI_BUILD_CONTEXT)
# This directory should contain package.json and your UI application
UI_SOURCE_PATH=ui/chat-web-app

# Path to nginx configuration for UI (relative to UI_BUILD_CONTEXT)
# This configures how nginx serves your built UI application
NGINX_UI_CONFIG_FILE_PATH=deployment/docker/all_in_one_kdcube/nginx/conf/nginx_ui.conf

# Runtime config is mounted into the UI container as /usr/share/nginx/html/config.json
# Suggested path (workdir): <workdir>/config/frontend.config.hardcoded.json
PATH_TO_FRONTEND_CONFIG_JSON=/absolute/path/to/workdir/config/frontend.config.hardcoded.json

# -----------------------------------------------------------------------------
# SECRETS SIDECAR (optional, local dev)
# -----------------------------------------------------------------------------
# Admin token required to inject secrets into the sidecar.
SECRETS_ADMIN_TOKEN=
# Comma-separated list of read tokens accepted by the sidecar.
SECRETS_READ_TOKENS=
# Per-service read tokens (runtime-only; leave blank in files).
SECRETS_TOKEN_INGRESS=
SECRETS_TOKEN_PROC=
# Token lifetime and max uses (per token).
SECRETS_TOKEN_TTL_SECONDS=600
SECRETS_TOKEN_MAX_USES=1000

# -----------------------------------------------------------------------------
# PROXY BUILD CONFIGURATION
# -----------------------------------------------------------------------------
# Configuration for building the reverse proxy (nginx)

# Common parent directory that can reach both platform and frontend repos
# Example: If you have /src/platform-repo and /src/frontend-repo, use /src
# This setup is for KDCube platform and KDCube frontend
PROXY_BUILD_CONTEXT=/absolute/path/to/kdcube-ai-app

# Path to Dockerfile_ProxyOpenResty (relative to PROXY_BUILD_CONTEXT)
# This Dockerfile is provided by the platform (OpenResty-based)
PROXY_DOCKERFILE_PATH=app/ai-app/deployment/docker/all_in_one_kdcube/Dockerfile_ProxyOpenResty

# Path to custom nginx proxy configuration (relative to PROXY_BUILD_CONTEXT)
# Use nginx/conf/nginx_proxy.conf for HTTP or nginx/conf/nginx_proxy_ssl.conf for HTTPS
NGINX_PROXY_CONFIG_FILE_PATH=app/ai-app/deployment/docker/all_in_one_kdcube/nginx/conf/nginx_proxy.conf
# Runtime proxy config path mounted by docker-compose
NGINX_PROXY_RUNTIME_CONFIG_PATH=./config/nginx_proxy.conf

# -----------------------------------------------------------------------------
# NEO4J CONFIGURATION
# -----------------------------------------------------------------------------
# Neo4j database configuration (used by docker-compose for interpolation)

# Neo4j authentication
# N4J_USER=neo4j
# N4J_PASSWORD=changeme_neo4j_password

# Neo4j memory settings
# N4J_PAGECACHE=1G
# N4J_HEAP_INITIAL=512m
# N4J_HEAP_MAX=1G

# -----------------------------------------------------------------------------
# KDCube Frontend port
# -----------------------------------------------------------------------------
KDCUBE_UI_PORT=5174

# -----------------------------------------------------------------------------
# KDCube services. All scaled horizontally via running multiple instances of each service.
# -----------------------------------------------------------------------------
CHAT_APP_PORT=8010
CHAT_PROCESSOR_PORT=8020
METRICS_PORT=8090

# -----------------------------------------------------------------------------
# Local infra (Postgres + Redis containers)
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DATABASE=kdcube
POSTGRES_PORT=5432

# Optional aliases for tooling that expects PG* vars
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=kdcube

POSTGRES_MAX_CONNECTIONS=200

REDIS_PASSWORD=redispass
