FROM python:3.12-slim

WORKDIR /app

COPY deployment/docker/all_in_one_kdcube/secrets/requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir -r /app/requirements.txt

COPY deployment/docker/all_in_one_kdcube/secrets/secrets_server.py /app/secrets_server.py
COPY deployment/docker/all_in_one_kdcube/secrets/secretsctl.py /app/secretsctl.py

ENV SECRETS_PORT=7777
ENV SECRETS_STORE_PATH=/run/kdcube-secrets/store.json

CMD ["python", "/app/secrets_server.py"]
