FROM python:3.12-slim

ENV PIP_NO_CACHE_DIR=1

RUN apt-get update && apt-get install -y --no-install-recommends \
    bash curl ca-certificates grep findutils patch ripgrep \
    fonts-noto fonts-noto-cjk fonts-noto-color-emoji \
    libmagic1 file \
    && rm -rf /var/lib/apt/lists/* && apt-get clean
RUN which patch && patch --version | head -n 1

# Isolated venv
RUN python -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH" \
    PLAYWRIGHT_BROWSERS_PATH=/opt/ms-playwright

# Install Python deps
COPY src/kdcube-ai-app/requirements-chat.txt requirements.txt
COPY src/kdcube-ai-app/requirements-aws.txt requirements-aws.txt
RUN pip install --upgrade pip && \
    pip install --no-cache-dir -r requirements.txt

# Install browser deps separately to keep pip layer cacheable.
# Chromium/Playwright is only needed for document rendering. It dominates image
# size on embedded/arm64 targets, so make it opt-out via a build-arg.
# Default INSTALL_CHROMIUM=1 preserves upstream behavior (browser installed);
# build with --build-arg INSTALL_CHROMIUM=0 for a slim, render-less image.
ARG INSTALL_CHROMIUM=1
RUN if [ "$INSTALL_CHROMIUM" = "1" ]; then \
        python -m playwright install --with-deps chromium && \
        chmod -R a+rX /opt/ms-playwright; \
    else \
        echo "INSTALL_CHROMIUM=0: skipping Chromium/Playwright install (slim image; set KDCUBE_DISABLE_DOC_RENDERING=1 at runtime)"; \
    fi

# Create unprivileged user for executor (but entrypoint runs as root)
RUN groupadd --gid 1001 executor && \
    useradd --uid 1001 --gid 1001 --no-create-home executor

# Generated code never needs setuid/setgid helpers. Remove these bits from the
# executor image so kernel/page-cache bugs have no obvious privilege target.
RUN find / -xdev \( -perm -4000 -o -perm -2000 \) -type f -exec chmod ug-s {} + || true

# --- Environment variables ---
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/opt/app \
    PATH="/opt/venv/bin:$PATH" \
    PY_CODE_EXEC_TIMEOUT=600

# Defensive: if a second OpenMP runtime (e.g. torch) ever coexists with faiss,
# let the process continue instead of aborting with OMP Error #15.
ENV KMP_DUPLICATE_LIB_OK=TRUE

# --- App code ---
# Copy app to /opt/app so kdcube_ai_app is at /opt/app/kdcube_ai_app
COPY src/kdcube-ai-app/ /opt/app/

WORKDIR /workspace

# --- Entrypoint ---
ENTRYPOINT ["python", "/opt/app/kdcube_ai_app/apps/chat/sdk/runtime/isolated/py_code_exec_entry.py"]
