{
  "family": "kdcube-chat-ingress",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "1024",
  "memory": "2048",
  "executionRoleArn": "arn:aws:iam::<ACCOUNT_ID>:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::<ACCOUNT_ID>:role/kdcube-chat-ingress-task-role",
  "containerDefinitions": [
    {
      "name": "chat-ingress",
      "image": "<ACCOUNT_ID>.dkr.ecr.<REGION>.amazonaws.com/kdcube-chat-ingress:<TAG>",
      "essential": true,
      "portMappings": [
        {
          "name": "api",
          "containerPort": 8010,
          "hostPort": 8010,
          "protocol": "tcp",
          "appProtocol": "http"
        }
      ],
      "environment": [
        {
          "name": "ENV",
          "value": "production"
        },
        {
          "name": "APP_PORT",
          "value": "8010"
        },
        {
          "name": "REDIS_HOST",
          "value": "<ELASTICACHE_REDIS_ENDPOINT>"
        },
        {
          "name": "REDIS_PORT",
          "value": "6379"
        },
        {
          "name": "DB_HOST",
          "value": "<RDS_ENDPOINT>"
        },
        {
          "name": "DB_PORT",
          "value": "5432"
        },
        {
          "name": "DB_NAME",
          "value": "kdcube"
        }
      ],
      "secrets": [
        {
          "name": "DB_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:<REGION>:<ACCOUNT_ID>:secret:kdcube/db-password"
        },
        {
          "name": "SECRET_KEY",
          "valueFrom": "arn:aws:secretsmanager:<REGION>:<ACCOUNT_ID>:secret:kdcube/secret-key"
        }
      ],
      "mountPoints": [],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/kdcube-chat-ingress",
          "awslogs-region": "<REGION>",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "curl -sf http://localhost:8010/monitoring/health || exit 1"
        ],
        "interval": 30,
        "timeout": 10,
        "retries": 3,
        "startPeriod": 30
      },
      "ulimits": [
        {
          "name": "nofile",
          "softLimit": 65536,
          "hardLimit": 65536
        }
      ],
      "stopTimeout": 60
    }
  ]
}
