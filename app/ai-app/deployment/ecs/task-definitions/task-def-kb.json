{
  "family": "kdcube-kb",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::<ACCOUNT_ID>:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::<ACCOUNT_ID>:role/kdcube-kb-task-role",
  "containerDefinitions": [
    {
      "name": "kb",
      "image": "<ACCOUNT_ID>.dkr.ecr.<REGION>.amazonaws.com/kdcube-kb:<TAG>",
      "essential": true,
      "portMappings": [
        {
          "name": "api",
          "containerPort": 8000,
          "hostPort": 8000,
          "protocol": "tcp",
          "appProtocol": "http"
        }
      ],
      "environment": [
        {
          "name": "ENV",
          "value": "production"
        },
        {
          "name": "APP_PORT",
          "value": "8000"
        },
        {
          "name": "DB_HOST",
          "value": "<RDS_ENDPOINT>"
        },
        {
          "name": "DB_PORT",
          "value": "5432"
        },
        {
          "name": "DB_NAME",
          "value": "kdcube"
        },
        {
          "name": "REDIS_HOST",
          "value": "<ELASTICACHE_REDIS_ENDPOINT>"
        },
        {
          "name": "REDIS_PORT",
          "value": "6379"
        }
      ],
      "secrets": [
        {
          "name": "DB_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:<REGION>:<ACCOUNT_ID>:secret:kdcube/db-password"
        },
        {
          "name": "OPENAI_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:<REGION>:<ACCOUNT_ID>:secret:kdcube/openai-api-key"
        }
      ],
      "mountPoints": [
        {
          "sourceVolume": "bundle-storage",
          "containerPath": "/bundle-storage",
          "readOnly": false
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/kdcube-kb",
          "awslogs-region": "<REGION>",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "curl -sf http://localhost:8000/health || exit 1"
        ],
        "interval": 30,
        "timeout": 10,
        "retries": 3,
        "startPeriod": 30
      },
      "stopTimeout": 60
    }
  ],
  "volumes": [
    {
      "name": "bundle-storage",
      "efsVolumeConfiguration": {
        "fileSystemId": "<EFS_FS_ID>",
        "rootDirectory": "/bundle-storage",
        "transitEncryption": "ENABLED",
        "authorizationConfig": {
          "accessPointId": "<EFS_ACCESS_POINT_ID>",
          "iam": "ENABLED"
        }
      }
    }
  ]
}
